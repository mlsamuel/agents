# OpenAI API key — required
OPENAI_API_KEY=sk-...

# Models
# Before SFT: both use gpt-4o-mini (specialist agents + fast calls)
# After SFT:  set MODEL_DEPLOYMENT_NAME=ft:gpt-4o-mini-... to use your fine-tuned model
#             as the specialist — the goal is to match gpt-4o quality at mini cost
MODEL_DEPLOYMENT_NAME=gpt-4o-mini
FAST_MODEL=gpt-4o-mini

# Set after running kb_setup.py
VECTOR_STORE_ID=

# Set after running sft/fine_tune.py
# To use in pipeline: set MODEL_DEPLOYMENT_NAME=<value below>
FINETUNED_MODEL=

# Logging: DEBUG for verbose agent output, INFO for normal
LOG_LEVEL=INFO

# Optional: OTLP collector endpoint for distributed tracing
# OTLP_ENDPOINT=http://localhost:4317
