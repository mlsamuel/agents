{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Classifier Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/classifier_agent.py",
            "python": "/opt/anaconda3/bin/python",
            "args": ["--limit", "5"],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Eval Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/eval_agent.py",
            "python": "/opt/anaconda3/bin/python",
            "args": ["--limit", "1", "--offset", "2"],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pipeline",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/pipeline.py",
            "python": "/opt/anaconda3/bin/python",
            "args": ["--limit", "2"],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
